# Copy to .env.local for local dev. In production, set these in the Vercel dashboard.
# NEVER commit real values.

# AI provider selection: 'anthropic' | 'openai'
# This is the DEFAULT — the UI can override per-request via { provider } in the body.
AI_PROVIDER=anthropic

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Metricool
METRICOOL_USER_TOKEN=replace-with-rotated-token-from-metricool-settings-api
METRICOOL_BLOG_ID=4308292
METRICOOL_USER_ID=3377431

# OpusClip (Pro/Business plan)
OPUS_API_KEY=replace-with-key-from-opus-dashboard-lower-left

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
